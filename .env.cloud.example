LF_RUNTIME_PROFILE=cloud
LF_PROJECT_NAME=vision-forge-cloud
LF_DOCKER_REQUIREMENTS_FILE=requirements/cpu.txt
LF_PUBLIC_PORT=8000
LF_DATABASE_HOST_PORT=5432
LF_DATABASE_NAME=vision_forge
LF_DATABASE_USER=vision_forge
LF_DATABASE_PASSWORD=change-me
LF_RUN_MIGRATIONS_ON_START=1

ENV=prod
DATABASE_URL=postgresql+psycopg2://vision_forge:change-me@db:5432/vision_forge
SECRET_KEY=replace-with-a-long-random-session-secret
# Optional: set this only when migrating legacy pre-Argon2 SHA-256 password hashes.
PASSWORD_SALT=
SESSION_COOKIE_NAME=vision_forge_session
SESSION_COOKIE_HTTPS_ONLY=1
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=1209600
# Enable only when a trusted reverse proxy terminates TLS and sets forwarding headers.
TRUST_PROXY_HEADERS=0
TRUSTED_PROXY_IPS=127.0.0.1
# Leave blank for same-origin deployments. If a browser frontend lives on a
# different origin, set an explicit comma-separated allowlist here.
CORS_ALLOW_ORIGINS=
#
# Optional: comma-separated import path(s) for private overlay hook modules.
# Example: APP_EXTENSION_HOOKS=vision_forge_enterprise.app_hooks
# APP_EXTENSION_HOOKS=

SAM2_ENABLED=0
SAM2_MODEL_CFG=configs/sam2.1/sam2.1_hiera_l.yaml
SAM2_CHECKPOINT=/app/models/sam2.1_hiera_large.pt
SAM2_DEVICE=cpu
SAM2_REQUIRE_GPU=0
SAM2_OFFLOAD_VIDEO_TO_CPU=0
SAM2_OFFLOAD_STATE_TO_CPU=0
SAM2_ASYNC_LOADING_FRAMES=0
SAM2_APPLY_POSTPROCESSING=1
SAM2_VOS_OPTIMIZED=0
LABELING_PROXY_ENABLED=1
LABELING_PROXY_CRF=12
LABELING_PROXY_PRESET=veryfast
LABELING_PROXY_MAX_WIDTH=0
LABELING_PROXY_GOP_SIZE=6
LABELING_PROXY_B_FRAMES=0
LABELING_PROXY_MAX_CONCURRENT_JOBS=2
LABELING_PROXY_STORAGE_BUDGET_GB=100
LABELING_PROXY_STORAGE_TTL_DAYS=14

# Disabled by default for self-hosted deployments. Temporarily enable only to
# seed the first admin account, then disable it again after sign-in.
BOOTSTRAP_DEFAULT_ADMIN_ENABLED=0
BOOTSTRAP_DEFAULT_ADMIN_EMAIL=
BOOTSTRAP_DEFAULT_ADMIN_PASSWORD=
